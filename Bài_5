#include <iostream>
#include <vector>
#include <cmath>
using namespace std;

class cDaThuc {
private:
    int n;
    vector<double> a;

public:
    cDaThuc(int degree = 0) {
        n = degree;
        a.resize(n + 1, 0);
    }

    void input() {
        cout << "Nhap bac da thuc: ";
        cin >> n;
        a.resize(n + 1);
        for (int i = 0; i <= n; i++) {
            cout << "a[" << i << "] = ";
            cin >> a[i];
        }
    }

    void output() {
        for (int i = n; i >= 0; i--) {
            if (a[i] != 0) {
                if (i != n && a[i] > 0) cout << " + ";
                if (a[i] < 0) cout << " - ";

                double val = abs(a[i]);
                if (i == 0) cout << val;
                else if (i == 1) cout << val << "x";
                else cout << val << "x^" << i;
            }
        }
        cout << endl;
    }

    double evaluate(double x) {
        double result = 0;
        for (int i = 0; i <= n; i++) {
            result += a[i] * pow(x, i);
        }
        return result;
    }

    cDaThuc add(const cDaThuc& p) {
        int maxDeg = max(n, p.n);
        cDaThuc result(maxDeg);

        for (int i = 0; i <= maxDeg; i++) {
            double h1 = (i <= n) ? a[i] : 0;
            double h2 = (i <= p.n) ? p.a[i] : 0;
            result.a[i] = h1 + h2;
        }
        return result;
    }

    cDaThuc subtract(const cDaThuc& p) {
        int maxDeg = max(n, p.n);
        cDaThuc result(maxDeg);

        for (int i = 0; i <= maxDeg; i++) {
            double h1 = (i <= n) ? a[i] : 0;
            double h2 = (i <= p.n) ? p.a[i] : 0;
            result.a[i] = h1 - h2;
        }
        return result;
    }
};

int main() {
    cDaThuc p1, p2;

    cout << "Nhap da thuc 1:\n";
    p1.input();

    cout << "\nNhap da thuc 2:\n";
    p2.input();

    cout << "\nDa thuc 1: ";
    p1.output();

    cout << "Da thuc 2: ";
    p2.output();

    double x;
    cout << "\nNhap gia tri x: ";
    cin >> x;

    cout << "P1(x) = " << p1.evaluate(x) << endl;
    cout << "P2(x) = " << p2.evaluate(x) << endl;

    cDaThuc sum = p1.add(p2);
    cout << "\nTong hai da thuc: ";
    sum.output();

    cDaThuc diff = p1.subtract(p2);
    cout << "Hieu hai da thuc: ";
    diff.output();

    return 0;
}
